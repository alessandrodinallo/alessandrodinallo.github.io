@article{dinallo2025partnership,
  title     = {The partnership context of first parenthood},
  author    = {Di Nallo, Alessandro},
  journal   = {Demographic Research},
  year      = {2025},
  doi       = {10.4054/DemRes.2025.53.16},
  url       = {https://doi.org/10.4054/DemRes.2025.53.16},
  abbr      = {DemRes},
  preview   = {dinallo2025partnership.jpg},
  img_caption = {Juno (2007), dir. Jason Reitman},
  note      = {When, and in which partnership, do people in the UK have their first child? Following individuals from their teens into adulthood, I show that those from working-class families become parents earlier and more often outside marriage, most often within cohabitation, while those from higher-class families delay parenthood and tend to have their first child within marriage. Cohabiting first births have become more common across all groups over successive cohorts, yet the class gradient in the timing and context of first parenthood persists.},
  selected  = {true}
}

@article{dinallo2025sleeping,
  title     = {Sleeping with the enemy. Partners' heterogamy by political preferences and union dissolution},
  author    = {Arpino, Bruno and Di Nallo, Alessandro},
  journal   = {Demography},
  year      = {2025},
  doi       = {10.1215/00703370-11983537},
  url       = {https://doi.org/10.1215/00703370-11983537},
  abbr      = {Demography},
  preview   = {dinallo2025sleeping.jpg},
  img_caption = {The Way We Were (1973), dir. Sydney Pollack},
  note      = {Do partners with opposing political views stay together? Drawing on nearly 29,000 British couples between 1991 and 2019, we find that political heterogamy is associated with a higher risk of union dissolution, an association that grew more visible around the Brexit referendum. The pattern suggests that political differences can erode relationship stability much like other forms of value mismatch, and that a polarised climate can make those differences harder to bridge.},
  selected  = {true}
}

@article{dinallo2025jobinsecurity,
  title     = {How perceived job insecurity, voluntary unemployment and involuntary job loss shape couples' life satisfaction},
  author    = {L{\'e}bert, Florence and Lipps, Oliver and Di Nallo, Alessandro},
  journal   = {Journal of Family and Economic Issues},
  year      = {2025},
  doi       = {10.1007/s10834-025-10062-8},
  url       = {https://link.springer.com/article/10.1007/s10834-025-10062-8},
  abbr      = {JFEI},
  preview   = {dinallo2025jobinsecurity.jpg},
  img_caption = {Pieces of a Woman (2020), dir. Kornél Mundruczó},
  note      = {Employment shocks are not all alike. Using German panel data, we compare how perceived job insecurity, voluntary unemployment and involuntary job loss each shape the life satisfaction of both partners, and find that the sharpest declines follow involuntary job loss. Both partners' well-being responds, not only that of the person who loses the job, underscoring that employment shocks are experienced at the level of the couple rather than the individual.}
}

