@article{dinallo2023fertility,
  title     = {How much his or her job loss influences fertility. A couple approach},
  author    = {Di Nallo, Alessandro and Lipps, Oliver},
  journal   = {Journal of Marriage and Family},
  year      = {2023},
  doi       = {10.1111/jomf.12907},
  url       = {https://onlinelibrary.wiley.com/doi/10.1111/jomf.12907},
  abbr      = {JMF},
  preview   = {dinallo2023fertility.jpg},
  img_caption = {Two Days, One Night (2014), dir. Jean-Pierre & Luc Dardenne},
  note      = {Does losing a job change a couple's plans to have children? Using UK and German longitudinal data, we find that unions hit by job loss, and especially by the woman's, are markedly less likely to go on to have a child. The effect concentrates in the years right after the job loss, consistent with couples postponing childbearing when economic security is threatened.}
}

@article{dinallo2023intergenerational,
  title     = {The intergenerational transmission of family dissolution},
  author    = {Di Nallo, Alessandro and Oesch, Daniel},
  journal   = {European Journal of Population},
  year      = {2023},
  doi       = {10.1007/s10680-023-09654-7},
  url       = {https://link.springer.com/article/10.1007/s10680-023-09654-7},
  abbr      = {EJP},
  preview   = {dinallo2023intergenerational.jpg},
  img_caption = {Kramer vs. Kramer (1979), dir. Robert Benton},
  note      = {Is divorce inherited? Using British cohort data, we show that parental union dissolution raises the chance that children's own partnerships dissolve, and that this intergenerational transmission is conditioned by social-class origin. Children from more advantaged backgrounds are partly buffered, so the reproduction of family instability is stratified rather than uniform.}
}

@article{dinallo2023repartnering,
  title     = {Repartnering of women in the USA: The interplay between motherhood and socioeconomic status},
  author    = {Di Nallo, Alessandro and Ivanova, Katya and Balbo, Nicoletta},
  journal   = {Population Studies},
  year      = {2023},
  doi       = {10.1080/00324728.2022.2152478},
  url       = {https://www.tandfonline.com/doi/full/10.1080/00324728.2022.2152478},
  abbr      = {Pop. Studies},
  preview   = {dinallo2023repartnering.jpg},
  img_caption = {The Florida Project (2017), dir. Sean Baker},
  note      = {After a break-up, who finds a new partner? Analysing US women, we find that motherhood substantially lowers the chances of repartnering for the low-educated, while it matters far less for the highly educated. For less-educated mothers, the combined demands of single parenthood and scarcer economic resources appear to narrow the opportunities to form a new union.}
}

