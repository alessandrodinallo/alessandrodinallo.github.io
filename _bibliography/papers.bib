@article{dinallo2025physicalhealth,
  title     = {Women's physical health around live births and pregnancy losses},
  author    = {Di Nallo, Alessandro},
  journal   = {European Journal of Public Health},
  year      = {2025},
  doi       = {10.1093/eurpub/ckaf013},
  url       = {https://doi.org/10.1093/eurpub/ckaf013},
  abbr      = {EJPH},
  preview   = {dinallo2025physicalhealth.jpg},
  img_caption = {Raining Stones (1993), dir. Ken Loach},
  note      = {How does the body fare around a pregnancy? Tracking women's physical health over time, I find a decline around births that is more pronounced, and slower to recover, among women who experienced a miscarriage or a stillbirth. The results point to pregnancy loss as an under-recognised marker of women's longer-term physical health, not only of their emotional well-being.}
}

